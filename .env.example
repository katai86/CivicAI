DB_HOST=localhost
DB_NAME=terkep
DB_USER=terkep
DB_PASS=

ADMIN_USER=admin
ADMIN_PASS=admin
ADMIN_TOKEN=

# Önkormányzati (govuser) regisztráció engedélyezése a nyilvános űrlapon. Ha 1/true: megjelenik a „Közigazgatási” opció.
GOV_REGISTRATION_ENABLED=0

IP_HASH_SALT=change_me
APP_BASE_URL=https://example.com/terkep

MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=Problematérkép

# FixMyStreet / Open311 bridge (opcionális). Ha üres, az Export FMS gomb nem érhető el.
FMS_OPEN311_BASE=
FMS_OPEN311_JURISDICTION=
FMS_OPEN311_API_KEY=

# AI (Mistral/Gemini) – bejelentés kategorizálás, kép elemzés. Gov/Admin felületen csak állapot látszik (beállítva/nincs).
AI_ENABLED=0
AI_PROVIDER=mistral
MISTRAL_API_KEY=
GEMINI_API_KEY=

# Model routing (task → modell). Ha üres, a kód defaultot használ.
# Kép / fa / közterületi objektum: vision primary + fallback
# AI_MODEL_VISION=  (pl. Ministral 3 14B / pixtral-12b-2409)
# AI_MODEL_VISION_FALLBACK=pixtral-12b-2409
# Rövid kategorizálás (bejelentés): Small 3.2
# AI_MODEL_SMALL=mistral-small-2506
# Összefoglalók / ESG / vezetői riport: Large 3 (fallback: Medium)
# AI_MODEL_LARGE=mistral-large-2512
# AI_MODEL_LARGE_FALLBACK=mistral-medium-2310
# Lakossági asszisztens: Medium 3.1 (fallback: Large)
# AI_MODEL_MEDIUM=mistral-medium-2310
# AI_MODEL_MEDIUM_FALLBACK=mistral-large-2512
# Dokumentum OCR (ahol releváns)
# AI_MODEL_OCR=
